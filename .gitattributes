# Auto detect text files and normalize line endings
* text=auto

# Unity source files
*.cs text diff=csharp

# Force Unity text-serialized assets to be treated as text & merged with Unity's tool
*.unity merge=unityyamlmerge eol=lf
*.prefab merge=unityyamlmerge eol=lf
*.asset merge=unityyamlmerge eol=lf
*.meta merge=unityyamlmerge eol=lf
*.controller merge=unityyamlmerge eol=lf
*.anim merge=unityyamlmerge eol=lf
*.physicMaterial merge=unityyamlmerge eol=lf
*.mat merge=unityyamlmerge eol=lf

# Treat common binary asset types as binary (no line-ending munging, no diff)
*.fbx binary
*.obj binary
*.blend binary
*.glb binary
*.gltf binary
*.png binary
*.jpg binary
*.jpeg binary
*.tga binary
*.tif binary
*.tiff binary
*.psd binary
*.exr binary
*.hdr binary
*.wav binary
*.mp3 binary
*.ogg binary
*.aif binary
*.mp4 binary
*.mov binary
*.ttf binary
*.otf binary
*.dll binary
*.so binary
*.a binary
*.aar binary
